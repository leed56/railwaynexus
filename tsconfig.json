{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": [
    "src/**/*.ts",
    "api/**/*.ts",
    "inngest/**/*.ts",
    "lib/**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "node_modules"
  ]
}
